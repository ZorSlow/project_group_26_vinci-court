<section class="background">
    <h1>Se connecter</h1>

    <form class="login-container" method="post" action="/users/login">
        <div>
            <label for="email">Email </label>
            <input type="text" name="email" placeholder="e-mail(@vinci.be, @student.vinci.be, @coach.vinci.be)" />
        </div>
        <div>
            <label for="password">Password </label>
            <input type="password" name="password" placeholder="password(8 caractères, minuscule, majuscule, chiffre)" />
        </div>
        {{#if error}}

        <p class="error-message">{{error}}</p>

        {{/if}}

        <input class="inputlog" type="submit" value="Me connecter">

    </form>
</section>