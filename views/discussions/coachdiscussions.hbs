<section>
<h1>Messages à répondre</h1>
{{#each discussions}}
    <div>
        <p>({{this.date_hour_message}}): {{this.message_text}} De:{{this.firstname}} {{this.surname}} </p>
        <form action="/discussions/response?response={{this.message_id}}" method="post">
            <textarea name="response" required></textarea>
            <button type="submit">Envoyer</button>
        </form>
    </div>
{{/each}}
</section>
